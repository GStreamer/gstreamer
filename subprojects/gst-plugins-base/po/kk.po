msgstr "Барлық жетіспейтін плагиндер орнатылуы мүмкін."

msgid "Some missing plugins could be installed."
msgstr "Кейбір жетіспейтін плагиндер орнатылуы мүмкін."

msgid ""
"The missing plugins could not be found in the available package repositories."
msgstr "Жетіспейтін плагиндер қолжетімді десте репозиторийлерінен табылмады."

msgid "An error occurred during plugin installation."
msgstr "Плагинді орнату кезінде қате орын алды."

msgid "Plugin installation was cancelled by the user."
msgstr "Плагинді орнатуды пайдаланушы тоқтатты."

msgid ""
"Something went wrong when trying to invoke the missing plugin installer."
msgstr "Жетіспейтін плагиндерді орнатушыны шақыру кезінде қате орын алды."

msgid "This system does not have a missing plugin handler installed."
msgstr "Бұл жүйеде жетіспейтін плагиндерді өңдеуші орнатылмаған."

msgid "Updating plugin registry for newly installed plugins.."
msgstr "Жаңадан орнатылған плагиндер үшін плагиндер тізілімі жаңартылуда.."

msgid "Error updating plugin registry."
msgstr "Плагиндер тізілімін жаңарту қатесі."

msgid "Buffering..."
msgstr "Аралық сақтау (Buffering)..."

msgid "Clock lost, selecting a new one\n"
msgstr "Уақыт жоғалды, жаңасы таңдалуда\n"

msgid "Reached end of play list."
msgstr "Ойнату тізімінің соңына жетті."

msgid "Paused"
msgstr "Аялдатылды"

#, c-format
msgid "Now playing %s\n"
msgstr "Қазір %s ойнатылуда\n"

#, c-format
msgid "About to finish, preparing next title: %s"
msgstr "Аяқталуға жақын, келесі тақырып дайындалуда: %s"

#, c-format
msgid "Playback rate: %.2f"
msgstr "Ойнату жылдамдығы: %.2f"

#, c-format
msgid "Could not change playback rate to %.2f"
msgstr "Ойнату жылдамдығын %.2f мәніне өзгерту мүмкін болмады"

msgid "space"
msgstr "бос орын"

msgid "pause/unpause"
msgstr "аялдату/жалғастыру"

msgid "q or ESC"
msgstr "q немесе ESC"

msgid "quit"
msgstr "шығу"

msgid "> or n"
msgstr "> немесе n"

msgid "play next"
msgstr "келесіні ойнату"

msgid "< or b"
msgstr "< немесе b"

msgid "play previous"
msgstr "алдыңғыны ойнату"

msgid "seek forward"
msgstr "алға іздеу"

msgid "seek backward"
msgstr "артқа іздеу"

msgid "volume up"
msgstr "дыбысты көтеру"

msgid "volume down"
msgstr "дыбысты азайту"

msgid "toggle audio mute on/off"
msgstr "дыбысты өшіруді қосу/сөндіру"

msgid "increase playback rate"
msgstr "ойнату жылдамдығын арттыру"

msgid "decrease playback rate"
msgstr "ойнату жылдамдығын азайту"

msgid "change playback direction"
msgstr "ойнату бағытын өзгерту"

msgid "enable/disable trick modes"
msgstr "трюк режимдерін іске қосу/сөндіру"

msgid "change to previous/next audio track"
msgstr "алдыңғы/келесі аудио трекке ауысу"

msgid "change to previous/next video track"
msgstr "алдыңғы/келесі видео трекке ауысу"

msgid "change to previous/next subtitle track"
msgstr "алдыңғы/келесі субтитр трегіне ауысу"

msgid "seek to beginning"
msgstr "басына қарай іздеу"

msgid "show keyboard shortcuts"
msgstr "пернетақта жарлықтарын көрсету"

msgid "Interactive mode - keyboard controls:"
msgstr "Интерактивті режим - пернетақта арқылы басқару:"

#, c-format
msgid "Use Windows high-resolution clock, precision: %u ms\n"
msgstr "Windows жоғары ажыратымдылықты сағатын пайдалану, дәлдігі: %u мс\n"

msgid "Output status information and property notifications"
msgstr "Күй туралы ақпаратты және қасиеттер туралы хабарландыруларды шығару"

msgid "Control playback behaviour setting playbin 'flags' property"
msgstr "Playbin 'flags' қасиетін баптау арқылы ойнату әрекетін басқару"

msgid "Video sink to use (default is autovideosink)"
msgstr "Пайдаланылатын видео қабылдағыш (әдепкі бойынша autovideosink)"

msgid "Audio sink to use (default is autoaudiosink)"
msgstr "Пайдаланылатын аудио қабылдағыш (әдепкі бойынша autoaudiosink)"

msgid "Enable gapless playback"
msgstr "Үзіліссіз ойнатуды іске қосу"

msgid "Enable instantaneous uri changes (only with playbin3)"
msgstr "URI-ды лезде өзгертуді іске қосу (тек playbin3-пен)"

msgid "Shuffle playlist"
msgstr "Ойнату тізімін араластыру"

msgid "Disable interactive control via the keyboard"
msgstr "Пернетақта арқылы интерактивті басқаруды сөндіру"

msgid "Volume"
msgstr "Дыбыс деңгейі"

msgid "Start position in seconds."
msgstr "Секундпен есептелген бастапқы позиция."

msgid "Enable accurate seeking"
msgstr "Дәл іздеуді іске қосу"

msgid "Playlist file containing input media files"
msgstr "Кіріс медиа файлдары бар ойнату тізімі файлы"

msgid "Use the experimental instant-rate-change flag when changing rate"
msgstr ""
"Жылдамдықты өзгерткен кезде эксперименттік instant-rate-change жалаушасын "
"пайдалану"

msgid "Do not print any output (apart from errors)"
msgstr "Ешқандай ақпаратты шығармау (қателерден басқа)"

msgid "Use playbin3 pipeline (default)"
msgstr "Playbin3 конвейерін пайдалану (әдепкі бойынша)"

msgid "Use playbin2 pipeline"
msgstr "Playbin2 конвейерін пайдалану"

msgid ""
"Keep showing the last frame on EOS until quit or playlist change command "
"(gapless is ignored)"
msgstr ""
"Шығу немесе ойнату тізімін өзгерту командасына дейін EOS кезінде соңғы "
"кадрды көрсетіп тұру (үзіліссіз ойнату еленбейді)"

msgid "Do not print current position of pipeline"
msgstr "Конвейердің ағымдағы позициясын шығармау"

msgid "Disable missing plugin installation"
msgstr "Жетіспейтін плагиндерді орнатуды сөндіру"

#, c-format
msgid "Usage: %s FILE1|URI1 [FILE2|URI2] [FILE3|URI3] ..."
msgstr "Қолданылуы: %s ФАЙЛ1|URI1 [ФАЙЛ2|URI2] [ФАЙЛ3|URI3] ..."

msgid "You must provide at least one filename or URI to play."
msgstr "Ойнату үшін кем дегенде бір файл атын немесе URI көрсетуіңіз керек."

msgid "Press 'k' to see a list of keyboard shortcuts.\n"
msgstr "Пернетақта жарлықтарының тізімін көру үшін 'k' пернесін басыңыз.\n"
