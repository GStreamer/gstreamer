From a33ac179bb45c3378188c21028abaded1271ea8c Mon Sep 17 00:00:00 2001
From: Nirbheek Chauhan <nirbheek@centricular.com>
Date: Sun, 26 Apr 2026 18:06:42 +0530
Subject: [PATCH 09/10] meson: Fix deprecation warning

gir/meson.build:233: DEPRECATION: Project uses feature that was always
broken, and is now deprecated since '1.3.0': str.format: Value other
than strings, integers, bools, options, dictionaries and lists
thereof..

(cherry picked from commit 0644cac02661e7dd980eec4ede297890608a4e09)
---
 gir/meson.build | 24 ++++++++++++++++++++----
 1 file changed, 20 insertions(+), 4 deletions(-)

diff --git a/gir/meson.build b/gir/meson.build
index 39e24748..0e741703 100644
--- a/gir/meson.build
+++ b/gir/meson.build
@@ -229,7 +229,11 @@ else
 endif
 
 foreach h : glib_headers
-  hstr = '@0@'.format(h)
+  if dep_type == 'internal'
+    hstr = h.full_path()
+  else
+    hstr = h
+  endif
   if not hstr.endswith('autocleanups.h')
     glib_files += h
   endif
@@ -305,7 +309,11 @@ else
 endif
 
 foreach h : gobject_headers
-  hstr = '@0@'.format(h)
+  if dep_type == 'internal'
+    hstr = h.full_path()
+  else
+    hstr = h
+  endif
   if not hstr.endswith('autocleanups.h') and not hstr.endswith('glib-types.h') and not hstr.endswith('gvaluecollector.h') and not hstr.endswith('glib-enumtypes.h')
     gobject_files += h
   endif
@@ -426,7 +434,11 @@ else
 endif
 
 foreach h : gio_headers
-  hstr = '@0@'.format(h)
+  if dep_type == 'internal'
+    hstr = h.full_path()
+  else
+    hstr = h
+  endif
   if not hstr.endswith('autocleanups.h')
     gio_files += h
   endif
@@ -452,7 +464,11 @@ if giounix_dep.found()
   # GIO Unix headers must be included explicitly since there is no catch-all
   # header that includes all of them unlike gio/gio.h above
   foreach header : giounix_headers
-    hstr = '@0@'.format(header)
+    if dep_type == 'internal'
+      hstr = h.full_path()
+    else
+      hstr = h
+    endif
     hbase = hstr.split('/')[-1]
     gio_command += '--c-include=gio/@0@'.format(hbase)
   endforeach
-- 
