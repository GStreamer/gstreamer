set-globals, media_dir="$(test_dir)/../../../media/defaults/mp4/"
meta,
    seek=false,
    handles-states=false,
    args = {
         "filesrc location=$(media_dir)/mp4box-tfdt-per-segment-not-per-fragment_dashinit.mp4 ! qtdemux name=d  d.video_0 ! queue max-size-buffers=0 max-size-bytes=0 max-size-time=1000000000 ! fakesink sync=false name=video-fakesink",
    },
    configs = {
       "$(validateflow), pad=video-fakesink:sink, record-buffers=true, logged-event-types={segment, eos}",
    }

