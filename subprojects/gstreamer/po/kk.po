#, c-format
msgid "ERROR: %s\n"
msgstr "ҚАТЕ: %s\n"

#, c-format
msgid ""
"Details:\n"
"%s\n"
msgstr ""
"Мәліметтер:\n"
"%s\n"

msgid "Setting pipeline to PLAYING ...\n"
msgstr "Конвейер ОЙНАТУ күйіне қойылуда ...\n"

msgid "ERROR: pipeline doesn't want to play.\n"
msgstr "ҚАТЕ: конвейер ойнатқысы келмейді.\n"

#, c-format
msgid "Got message #%u from element \"%s\" (%s): "
msgstr "«%2$s» (%3$s) элементінен №%1$u хабарлама алынды: "

#, c-format
msgid "Got message #%u from pad \"%s:%s\" (%s): "
msgstr "«%2$s:%3$s» (%4$s) блогынан (pad) №%1$u хабарлама алынды: "

#, c-format
msgid "Got message #%u from object \"%s\" (%s): "
msgstr "«%2$s» (%3$s) объектісінен №%1$u хабарлама алынды: "

#, c-format
msgid "Got message #%u (%s): "
msgstr "№%u (%s) хабарлама алынды: "

#, c-format
msgid "Got EOS from element \"%s\".\n"
msgstr "«%s» элементінен ағын соңы (EOS) алынды.\n"

msgid "EOS received - stopping pipeline...\n"
msgstr "Ағын соңы (EOS) алынды — конвейер тоқтатылуда...\n"

#, c-format
msgid "FOUND TAG      : found by element \"%s\".\n"
msgstr "ТЕГ ТАБЫЛДЫ      : «%s» элементі тапты.\n"

#, c-format
msgid "FOUND TAG      : found by pad \"%s:%s\".\n"
msgstr "ТЕГ ТАБЫЛДЫ      : «%s:%s» блогы тапты.\n"

#, c-format
msgid "FOUND TAG      : found by object \"%s\".\n"
msgstr "ТЕГ ТАБЫЛДЫ      : «%s» объектісі тапты.\n"

msgid "FOUND TAG\n"
msgstr "ТЕГ ТАБЫЛДЫ\n"

#, c-format
msgid "FOUND TOC      : found by element \"%s\".\n"
msgstr "МАЗМҰН (TOC) ТАБЫЛДЫ : «%s» элементі тапты.\n"

#, c-format
msgid "FOUND TOC      : found by object \"%s\".\n"
msgstr "МАЗМҰН (TOC) ТАБЫЛДЫ : «%s» объектісі тапты.\n"

msgid "FOUND TOC\n"
msgstr "МАЗМҰН (TOC) ТАБЫЛДЫ\n"

#, c-format
msgid ""
"INFO:\n"
"%s\n"
msgstr ""
"АҚПАРАТ:\n"
"%s\n"

#, c-format
msgid "WARNING: from element %s: %s\n"
msgstr "ЕСКЕРТУ: %s элементінен: %s\n"

msgid "Pipeline is PREROLLED ...\n"
msgstr "Конвейер ДАЙЫН (PREROLLED) ...\n"

msgid "Prerolled, waiting for buffering to finish...\n"
msgstr "Дайын, буферлеудің аяқталуы күтілуде...\n"

msgid "Prerolled, waiting for progress to finish...\n"
msgstr "Дайын, орындалудың аяқталуы күтілуде...\n"

msgid "buffering..."
msgstr "буферлеу..."

msgid "Done buffering, setting pipeline to PLAYING ...\n"
msgstr "Буферлеу аяқталды, конвейер ОЙНАТУ күйіне қойылуда ...\n"

#. we were not buffering but PLAYING, PAUSE  the pipeline.
msgid "Buffering, setting pipeline to PAUSED ...\n"
msgstr "Буферлеу, конвейер АЯЛДАТУ күйіне қойылуда ...\n"

msgid "Redistribute latency...\n"
msgstr "Күту уақытын қайта бөлу...\n"

#, c-format
msgid "Setting state to %s as requested by %s...\n"
msgstr "%2$s сұрауы бойынша күй %1$s мәніне орнатылуда...\n"

#. this application message is posted when we caught an interrupt and
#. * we need to stop the pipeline.
msgid "Interrupt: Stopping pipeline ...\n"
msgstr "Үзіліс: Конвейер тоқтатылуда ...\n"

msgid "Interrupt while waiting for EOS - stopping pipeline...\n"
msgstr "Ағын соңын (EOS) күту кезіндегі үзіліс — конвейер тоқтатылуда...\n"

msgid "EOS on shutdown enabled -- Forcing EOS on the pipeline\n"
msgstr ""
"Жұмысты аяқтау кезіндегі ағын соңы (EOS) іске қосылған — Конвейерге EOS "
"мәжбүрлеу\n"

msgid "Waiting for EOS...\n"
msgstr "Ағын соңы (EOS) күтілуде...\n"

#, c-format
msgid "Progress: (%s) %s\n"
msgstr "Орындалуы: (%s) %s\n"

#, c-format
msgid "Missing element: %s\n"
msgstr "Жетіспейтін элемент: %s\n"

#, c-format
msgid "Got context from element '%s': %s=%s\n"
msgstr "«%s» элементінен контекст алынды: %s=%s\n"

msgid "ERROR: pipeline doesn't want to preroll.\n"
msgstr "ҚАТЕ: конвейер дайын (preroll) болғысы келмейді.\n"

msgid "An error happened while waiting for EOS\n"
msgstr "Ағын соңын (EOS) күту кезінде қате орын алды\n"

#, c-format
msgid "Use Windows high-resolution clock, precision: %u ms\n"
msgstr "Windows-тың жоғары дәлдікті сағатын пайдалану, дәлдік: %u мс\n"

msgid "Output tags (also known as metadata)"
msgstr "Тегтерді шығару (метадеректер ретінде де белгілі)"

msgid "Output TOC (chapters and editions)"
msgstr "Мазмұнды (TOC) шығару (тараулар мен басылымдар)"

msgid "Output status information and property notifications"
msgstr "Күй туралы ақпаратты және қасиет туралы хабарландыруларды шығару"

msgid "Do not print any progress information"
msgstr "Ешқандай орындалу ақпаратын шығармау"

msgid "Output messages"
msgstr "Хабарламаларды шығару"

msgid ""
"Do not output status information for the specified property if verbose "
"output is enabled (can be used multiple times)"
msgstr ""
"Егер толық (verbose) шығыс іске қосылған болса, көрсетілген қасиет үшін күй "
"ақпаратын шығармау (бірнеше рет пайдалануға болады)"

msgid "PROPERTY-NAME"
msgstr "ҚАСИЕТ-АТЫ"

msgid "Set the name of the program"
msgstr "Бағдарламаның атын орнату"

msgid "PROGRAM-NAME"
msgstr "БАҒДАРЛАМА-АТЫ"

msgid "Do not install a fault handler"
msgstr "Қателерді өңдеушіні орнатпау"

msgid "Force EOS on sources before shutting the pipeline down"
msgstr "Конвейерді жабу алдында көздерге (sources) ағын соңын (EOS) мәжбүрлеу"

msgid "Gather and print index statistics"
msgstr "Индекс статистикасын жинау және шығару"

msgid ""
"Do not print current position of pipeline. If this option is unspecified, "
"the position will be printed when stdout is a TTY. To enable printing "
"position when stdout is not a TTY, use \"force-position\" option"
msgstr ""
"Конвейердің ағымдағы орнын шығармау. Егер бұл опция көрсетілмесе, stdout TTY "
"болған кезде орын шығарылады. stdout TTY болмаған кезде орынды шығаруды іске "
"қосу үшін «force-position» опциясын пайдаланыңыз"

msgid ""
"Allow printing current position of pipeline even if stdout is not a TTY. "
"This option has no effect if the \"no-position\" option is specified"
msgstr ""
"Stdout TTY болмаса да, конвейердің ағымдағы орнын шығаруға рұқсат беру. Егер "
"«no-position» опциясы көрсетілсе, бұл опцияның әсері болмайды"

#, c-format
msgid "ERROR: pipeline could not be constructed: %s.\n"
msgstr "ҚАТЕ: конвейерді құрастыру мүмкін болмады: %s.\n"

msgid "ERROR: pipeline could not be constructed.\n"
msgstr "ҚАТЕ: конвейерді құрастыру мүмкін болмады.\n"

#, c-format
msgid "WARNING: erroneous pipeline: %s\n"
msgstr "ЕСКЕРТУ: қате конвейер: %s\n"

msgid "ERROR: the 'pipeline' element wasn't found.\n"
msgstr "ҚАТЕ: 'pipeline' элементі табылмады.\n"

msgid "Setting pipeline to PAUSED ...\n"
msgstr "Конвейер АЯЛДАТУ күйіне қойылуда ...\n"

msgid "Failed to set pipeline to PAUSED.\n"
msgstr "Конвейерді АЯЛДАТУ күйіне қою сәтсіз аяқталды.\n"

msgid "Pipeline is live and does not need PREROLL ...\n"
msgstr "Конвейер тікелей эфирде және оған ДАЙЫНДАУ (PREROLL) қажет емес ...\n"

msgid "Pipeline is PREROLLING ...\n"
msgstr "Конвейер ДАЙЫНДАЛУДА (PREROLLING) ...\n"

msgid "Execution ended after %"
msgstr "Орындау % соң аяқталды"

msgid "Setting pipeline to NULL ...\n"
msgstr "Конвейер НӨЛ (NULL) күйіне қойылуда ...\n"

msgid "Freeing pipeline ...\n"
msgstr "Конвейер босатылуда ...\n"
